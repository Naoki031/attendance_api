NODE_ENV=development
API_PREFIX=api/v1
PORT=3001

# Client base URL — used to generate clickable links in Slack notifications
CLIENT_URL=http://localhost

DB_DIALECT=mysql
DB_HOST=attendance_mariadb
DB_PORT=3306
DB_NAME=attendance
DB_USER=root
DB_PASS=password

BEARER=Bearer
JWT_KEY=random_secret_key
JWT_EXPIRATION_TIME=3600
SALT_ROUNDS=10

TYPEORM_MIGRATIONS=src/core/database/migrations/**/*{.ts,.js}
TYPEORM_SEEDING_FACTORIES=src/core/database/factories/**/*{.ts,.js}
TYPEORM_SEEDING_SEEDS=src/core/database/seeds/**/*{.ts,.js}

# Google Sheets integration (optional — leave blank to disable)
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_SHEET_NAME=Leave Requests
# Option 1 (recommended): path to service account JSON file
GOOGLE_SHEETS_KEY_FILE=secrets/google-sheet.json
# Option 2: paste the entire JSON as a single line (overridden by KEY_FILE if both set)
GOOGLE_SHEETS_CREDENTIALS=

# ZKTeco attendance device
ZK_DEVICE_IP=
ZK_DEVICE_PORT=4370
ZK_DEVICE_TIMEOUT=5000
ZK_SYNC_FROM_DATE=2025-01-01

# Set to true to enable automatic attendance sync every minute (default: false)
ZK_AUTO_SYNC_ENABLED=false

# Comma-separated list of allowed device serial numbers (leave empty to allow all during dev)
ZK_ALLOWED_SNS=

# Secret key for generating QR codes for employee check-in (keep this secure in production)
QR_SECRET=

# Optional: enable detailed logging of ZK device interactions (useful for debugging)
ANTHROPIC_API_KEY=

# Chatbot name (used in Slack notifications and UI) — default: HanaBot
CHATBOT_NAME="Baby Shark"

# Chatbot tone/personality (default: professional, can be overridden per-request from UI)
# Options: professional, friendly, humorous, empathetic, concise
CHATBOT_TONE=professional

# Chatbot model (default, can be overridden per-request from UI)
# Options: claude-sonnet-4-6 (default)
CHATBOT_MODEL=claude-sonnet-4-6

# Optional: separate model for translation tasks (e.g. translating leave requests from non-English speakers)
TRANSLATE_MODEL=claude-haiku-4-5-20251001
TRANSLATE_MAX_TOKENS=8192
TRANSLATE_MAX_INPUT_LENGTH=5000

# Slack webhook for system error notifications (auto-sync failures, internal errors, etc.)
# Configured via env — independent of the slack_channels table (which is for user bug reports)
# Leave blank to disable system error notifications
SLACK_ERROR_WEBHOOK_URL=

# Optional: override the channel the webhook posts to (e.g. #dev-alerts or C01234567)
# Leave blank to use the channel configured in the webhook itself
SLACK_ERROR_CHANNEL_ID=

# Comma-separated Slack user IDs to @mention in system error messages (e.g. U012AB3CD,U9876ZYXW)
SLACK_ERROR_MENTION_USER_IDS=

# Comma-separated Slack group handles to @mention (e.g. here,channel or subteam IDs like S1234567)
SLACK_ERROR_MENTION_GROUPS=

# S3 / MinIO storage (for face recognition avatar and check-in photos)
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY=your_access_key
AWS_SECRET_KEY=your_secret_key
S3_BUCKET=attendance
# Uncomment the lines below if using MinIO instead of AWS S3
# S3_ENDPOINT=http://localhost:9000
# S3_PUBLIC_URL=http://localhost:9000/attendance

# Firebase Admin SDK (for push notifications via FCM)
# Download service account JSON from Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=


# Feature flags — set to "false" to disable for all users except test accounts
# Defaults to enabled (true) if not set
FEATURE_QR_CHECKIN=true
FEATURE_FACE_CHECKIN=true

# Comma-separated user IDs allowed to access disabled features (test accounts)
# Example: TEST_USER_IDS=1,2,3
TEST_USER_IDS=

# ─────────────────────────────────────────────
# Meeting feature
# ─────────────────────────────────────────────

# LiveKit — WebRTC media server (self-hosted)
# Generate a random key pair for dev — use strong random strings in production
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
# URL accessible from inside Docker network
LIVEKIT_HOST=http://livekit:7880

# Whisper — speech-to-text (self-hosted Python service)
WHISPER_URL=http://whisper:5001

# Set to false to disable speech-to-text transcription for subtitles (default: true)
STT_ENABLED=false

# Google Cloud TTS — Wavenet voices for translated speech
# Create a restricted API key at console.cloud.google.com (enable "Cloud Text-to-Speech API")
# Free quota: 1,000,000 characters/month (Wavenet) — sufficient for ~15 min/day of meetings
GOOGLE_TTS_API_KEY=

# Groq — cloud Whisper API (much faster than local CPU)
# Free tier: 30 req/min, 14400 req/day — sufficient for ~4h/day of meetings
# Get key at: https://console.groq.com/keys
GROQ_API_KEY=

# ─────────────────────────────────────────────
# Mail (SMTP) — for scheduled participant RSVP emails
# ─────────────────────────────────────────────
MAIL_HOST=mailhog  # docker service name; change to smtp.gmail.com etc. for production
MAIL_PORT=1025   # MailHog SMTP port; use 587 for Gmail etc.
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM=Attendance <noreply@attendance.app>
